{
  "name": "snake-game",
  "version": "1.0.0",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win portable"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0"
  },
  "build": {
    "appId": "com.snakegame.app",
    "productName": "Snake Game",
    "win": {
      "icon": "icon.png",
      "target": "portable"
    },
    "portable": {
      "artifactName": "SnakeGame.exe"
    }
  }
}
